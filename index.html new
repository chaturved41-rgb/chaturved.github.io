<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CHEAP AND BEST SALOON</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Roboto', sans-serif;
        }

        body {
            background-color: #f5f5f5;
            color: #333;
            line-height: 1.6;
        }

        header {
            background: linear-gradient(to right, #f7f7f7, #333);
            color: #fff;
            padding: 20px 0;
            text-align: center;
        }

        header h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            color: #ffcc00;
        }

        header p {
            font-size: 1.2rem;
        }

        nav {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 10px;
        }

        nav a {
            color: #fff;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
        }

        nav a:hover {
            color: #ffcc00;
        }

        .hero {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: url('https://images.unsplash.com/photo-1605902711622-cfb43c44317d') no-repeat center center/cover;
            height: 80vh;
            color: #fff;
            text-align: center;
            padding: 0 20px;
        }

        .hero h2 {
            font-size: 3rem;
            margin-bottom: 20px;
            text-shadow: 2px 2px 5px #000;
        }

        .hero p {
            font-size: 1.2rem;
            margin-bottom: 30px;
            text-shadow: 1px 1px 3px #000;
        }

        .btn {
            background-color: #ffcc00;
            color: #333;
            padding: 12px 30px;
            text-decoration: none;
            font-weight: bold;
            border-radius: 5px;
            transition: 0.3s;
        }

        .btn:hover {
            background-color: #e6b800;
        }

        section {
            padding: 60px 20px;
            text-align: center;
        }

        section h2 {
            font-size: 2.5rem;
            margin-bottom: 20px;
            color: #333;
        }

        .services, .products {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
        }

        .card {
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            width: 250px;
            padding: 20px;
            text-align: center;
            transition: 0.3s;
        }

        .card img {
            width: 100%;
            border-radius: 10px;
            margin-bottom: 15px;
        }

        .card h3 {
            font-size: 1.5rem;
            margin-bottom: 10px;
        }

        .card p {
            font-size: 1rem;
            margin-bottom: 10px;
        }

        .card span {
            font-weight: bold;
            color: #ff6600;
        }

        footer {
            background: #333;
            color: #fff;
            text-align: center;
            padding: 20px 0;
        }

        footer p {
            margin-bottom: 5px;
        }

        @media(max-width:768px) {
            .services, .products {
                flex-direction: column;
                align-items: center;
            }

            .hero h2 {
                font-size: 2rem;
            }

            .hero p {
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header>
        <h1>CHEAP AND BEST SALOON</h1>
        <p>Professional Barbers | Beardo Products | Affordable Prices</p>
        <nav>
            <a href="#services">Services</a>
            <a href="#products">Products</a>
            <a href="#contact">Contact</a>
        </nav>
    </header>

    <!-- Hero Section -->
    <div class="hero">
        <h2>Look Sharp, Feel Confident!</h2>
        <p>Top-notch grooming with premium Beardo products at affordable prices.</p>
        <a href="#contact" class="btn">Book Your Appointment</a>
    </div>

    <!-- Services Section -->
    <section id="services">
        <h2>Our Services</h2>
        <div class="services">
            <div class="card">
                <img src="https://images.unsplash.com/photo-1598300050702-8c4d2c2a4b50" alt="Haircut">
                <h3>Haircut</h3>
                <p>Professional haircut by expert barbers.</p>
                <span>₹150</span>
            </div>
            <div class="card">
                <img src="https://images.unsplash.com/photo-1588776814546-5f421c6fa8e0" alt="Beard Styling">
                <h3>Beard Styling</h3>
                <p>Stylish beard grooming with premium products.</p>
                <span>₹200</span>
            </div>
            <div class="card">
                <img src="https://images.unsplash.com/photo-1600195077072-cfbb6c09b3d8" alt="Shaving">
                <h3>Shaving</h3>
                <p>Clean and comfortable shaving experience.</p>
                <span>₹100</span>
            </div>
        </div>
    </section>

    <!-- Products Section -->
    <section id="products" style="background-color:#f0f0f0;">
        <h2>Beardo Products</h2>
        <div class="products">
            <div class="card">
                <img src="https://cdn.shopify.com/s/files/1/0272/0405/1262/products/beardo-beard-oil.jpg" alt="Beard Oil">
                <h3>Beard Oil</h3>
                <p>Nourish your beard with premium oils.</p>
                <span>₹299</span>
            </div>
            <div class="card">
                <img src="https://cdn.shopify.com/s/files/1/0272/0405/1262/products/beardo-perfume.jpg" alt="Perfume">
                <h3>Beardo Perfume</h3>
                <p>Fragrances to suit every mood.</p>
                <span>₹499</span>
            </div>
            <div class="card">
                <img src="https://cdn.shopify.com/s/files/1/0272/0405/1262/products/beardo-grooming-kit.jpg" alt="Grooming Kit">
                <h3>Grooming Kit</h3>
                <p>Complete grooming solutions in one kit.</p>
                <span>₹799</span>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact">
        <h2>Contact Us</h2>
        <p>📍 Visit: Your Local Address Here</p>
        <p>📞 Call: +91 98765 43210</p>
        <p>📧 Email: info@cheapandbestsaloon.com</p>
    </section>

    <!-- Footer -->
    <footer>
        <p>© 2026 CHEAP AND BEST SALOON</p>
        <p>Follow us on social media: Instagram | Facebook | WhatsApp</p>
    </footer>

</body>
</html>
